{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "midnightInk": "#101426",
    "nearBlack": "#12131A",
    "inkPanel": "#171B30",
    "inkElement": "#1E2340",
    "inkBorder": "#2A2F4D",
    "inkBorderSubtle": "#1C2038",
    "paperCream": "#F5F1E8",
    "creamPanel": "#EDE7D8",
    "creamElement": "#E4DCC9",
    "creamBorder": "#D8CFBB",
    "cobalt": "#4D5DFF",
    "cobaltInk": "#3A46C7",
    "lilac": "#B8A8FF",
    "lilacInk": "#6A5ACD",
    "seafoam": "#73D9C2",
    "seafoamInk": "#2FA88C",
    "coral": "#FF6257",
    "coralInk": "#D23B31",
    "butter": "#FFD76A",
    "butterInk": "#B98A12",
    "mutedDark": "#8B86A8",
    "mutedLight": "#5B5670"
  },
  "theme": {
    "primary": { "dark": "cobalt", "light": "cobaltInk" },
    "secondary": { "dark": "lilac", "light": "lilacInk" },
    "accent": { "dark": "seafoam", "light": "seafoamInk" },
    "info": { "dark": "cobalt", "light": "cobaltInk" },
    "success": { "dark": "seafoam", "light": "seafoamInk" },
    "warning": { "dark": "butter", "light": "butterInk" },
    "error": { "dark": "coral", "light": "coralInk" },

    "text": { "dark": "paperCream", "light": "midnightInk" },
    "textMuted": { "dark": "mutedDark", "light": "mutedLight" },

    "background": { "dark": "midnightInk", "light": "paperCream" },
    "backgroundPanel": { "dark": "inkPanel", "light": "creamPanel" },
    "backgroundElement": { "dark": "inkElement", "light": "creamElement" },

    "border": { "dark": "inkBorder", "light": "creamBorder" },
    "borderActive": { "dark": "cobalt", "light": "cobaltInk" },
    "borderSubtle": { "dark": "inkBorderSubtle", "light": "creamBorder" },

    "diffAdded": { "dark": "seafoam", "light": "seafoamInk" },
    "diffRemoved": { "dark": "coral", "light": "coralInk" },
    "diffContext": { "dark": "mutedDark", "light": "mutedLight" },
    "diffHunkHeader": { "dark": "lilac", "light": "lilacInk" },
    "diffHighlightAdded": { "dark": "seafoam", "light": "seafoamInk" },
    "diffHighlightRemoved": { "dark": "coral", "light": "coralInk" },
    "diffAddedBg": { "dark": "#15302A", "light": "#DDEFE9" },
    "diffRemovedBg": { "dark": "#3A1B1A", "light": "#F6DEDC" },
    "diffContextBg": { "dark": "inkPanel", "light": "creamPanel" },
    "diffLineNumber": { "dark": "mutedDark", "light": "mutedLight" },
    "diffAddedLineNumberBg": { "dark": "#1B3A33", "light": "#CFE8E0" },
    "diffRemovedLineNumberBg": { "dark": "#472220", "light": "#EED2CF" },

    "markdownText": { "dark": "paperCream", "light": "midnightInk" },
    "markdownHeading": { "dark": "cobalt", "light": "cobaltInk" },
    "markdownLink": { "dark": "cobalt", "light": "cobaltInk" },
    "markdownLinkText": { "dark": "lilac", "light": "lilacInk" },
    "markdownCode": { "dark": "seafoam", "light": "seafoamInk" },
    "markdownBlockQuote": { "dark": "lilac", "light": "lilacInk" },
    "markdownEmph": { "dark": "lilac", "light": "lilacInk" },
    "markdownStrong": { "dark": "paperCream", "light": "midnightInk" },
    "markdownHorizontalRule": { "dark": "inkBorder", "light": "creamBorder" },
    "markdownListItem": { "dark": "paperCream", "light": "midnightInk" },
    "markdownListEnumeration": { "dark": "cobalt", "light": "cobaltInk" },
    "markdownImage": { "dark": "cobalt", "light": "cobaltInk" },
    "markdownImageText": { "dark": "lilac", "light": "lilacInk" },
    "markdownCodeBlock": { "dark": "paperCream", "light": "midnightInk" },

    "syntaxComment": { "dark": "mutedDark", "light": "mutedLight" },
    "syntaxKeyword": { "dark": "cobalt", "light": "cobaltInk" },
    "syntaxFunction": { "dark": "lilac", "light": "lilacInk" },
    "syntaxVariable": { "dark": "paperCream", "light": "midnightInk" },
    "syntaxString": { "dark": "seafoam", "light": "seafoamInk" },
    "syntaxNumber": { "dark": "butter", "light": "butterInk" },
    "syntaxType": { "dark": "lilac", "light": "lilacInk" },
    "syntaxOperator": { "dark": "coral", "light": "coralInk" },
    "syntaxPunctuation": { "dark": "mutedDark", "light": "mutedLight" }
  }
}
